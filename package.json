{
  "name": "composia-ai",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "build": "pnpm build:frontend && pnpm build:backend",
    "build:frontend": "vite build",
    "build:backend": "esbuild api/index.ts --bundle --packages=external --platform=node --target=node20 --format=esm --outfile=dist-api/index.js",
    "start": "cross-env NODE_ENV=production node dist-api/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:all": "biome check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx drizzle/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:regression": "playwright test --grep @regression",
    "test:e2e:visual": "playwright test --grep @visual",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "biome format --write .",
    "verify": "pnpm typecheck && pnpm lint && pnpm test run"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.12",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@json-render/core": "^0.18.0",
    "@json-render/react": "^0.18.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-table": "^8.21.3",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.3",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^1.7.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@hono/vite-dev-server": "^0.25.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.5",
    "husky": "^9.1.7",
    "msw": "^2.12.14",
    "pino-pretty": "^13.1.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
